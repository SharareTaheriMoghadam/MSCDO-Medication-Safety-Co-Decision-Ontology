loinc:LP29684-5 rdf:type owl:Class ;

                rdfs:subClassOf
msdo:LaboratoryParameter .





### 
http://purl.bioontology.org/ontology/MEDDRA/10002034

<http://purl.bioontology.org/ontology/MEDDRA/10002034> rdf:type owl:Class
;

                                                      
rdfs:subClassOf msdo:AdverseDrugEvent ,

                                                                      
msdo:MedicationRelatedRisk .





### 
