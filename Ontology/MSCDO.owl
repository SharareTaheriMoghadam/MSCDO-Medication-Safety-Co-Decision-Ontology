              msdo:hasSeverity
msdo:HighSeverity ;

              msdo:interactsWith
msdo:Amiodarone .





#################################################################

#    Rules



#################################################################

 



<d>
rdf:type <http://www.w3.org/2003/11/swrl#Variable> .



<adr> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .



<d1> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .



<d2> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .



<x> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .



