rxnorm:ClinicalDrug ;

                   rdfs:range
msdo:Medication ,

                             
msdo:MedicationEntity ,

                             
rxnorm:ClinicalDrug .





### 
http://example.org/msdo#mitigatedBy

msdo:mitigatedBy rdf:type owl:ObjectProperty ;

                 rdfs:domain msdo:MedicationRelatedRisk ;

                 rdfs:range
msdo:MitigatingAction .





### 
http://example.org/msdo#overriddenBy

msdo:overriddenBy rdf:type owl:ObjectProperty ;

                  rdfs:domain
msdo:DecisionArtifact ,

                             
msdo:Recommendation ;

                  rdfs:range
msdo:Clinician .





### 
http://example.org/msdo#prescribedDrug

msdo:prescribedDrug rdf:type owl:ObjectProperty ;

