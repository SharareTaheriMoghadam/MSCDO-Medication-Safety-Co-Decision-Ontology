msdo:TherapeuticClass rdf:type owl:Class ;

                      owl:equivalentClass
atc:ATCCode ;

                      rdfs:subClassOf
atc:ATCCode ;

                      rdfs:comment
"Pharmacological or therapeutic grouping of medications." .





